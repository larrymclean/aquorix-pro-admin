                target="_blank"
                rel="noopener noreferrer"
                style={{
                  color: "#7b8794",
                  textDecoration: "none",
                  fontFamily: '"Avenir Next", Avenir, "Helvetica Neue", Helvetica, Arial, sans-serif',
                  fontWeight: 600,
                  cursor: "pointer",
                }}
              >
                AQUORIX™
              </a>
            </div>
          </div>
        </div>
