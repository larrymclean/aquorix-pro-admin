                      <td
                        style={{
                          textAlign: "right",
                          padding: 12,
                          fontWeight: 900,
                          fontSize: 16,
                          color: "#075c31",
                          borderTop: "2px solid #075c31",
                          whiteSpace: "nowrap",
                        }}
                      >
                        {formatMinorCurrency(Math.round(finalTotal * itineraryMinorUnitDivisor), itineraryCurrency)}
                      </td>
                      <td
                        style={{
                          borderTop: "2px solid #075c31",
                          padding: 12,
                          textAlign: "right",
                        }}
                      >
                        <button
                          type="button"
                          onClick={clearItinerary}
                          style={{
                            padding: "8px 12px",
                            borderRadius: 10,
                            border: "1px solid #cfd6dd",
                            background: "#ffffff",
                            cursor: "pointer",
                            fontWeight: 800,
                            whiteSpace: "nowrap",
                          }}
                        >
                          Clear
                        </button>
                      </td>
                    </tr>
                  </tfoot>
                </table>

                <div style={{ fontSize: 12, marginTop: 8, color: "#5f6b76" }}>
